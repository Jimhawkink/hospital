{
    "version": 2,
    "installCommand": "npm install && cd packages/backend && npm install && cd ../frontend && npm install",
    "buildCommand": "cd packages/backend && npm run build && cd ../frontend && npm run build",
    "outputDirectory": "packages/frontend/dist",
    "functions": {
        "api/[...all].ts": {
            "maxDuration": 30,
            "includeFiles": "packages/backend/dist/**"
        },
        "api/**/*.{ts,js}": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/:path((?!health|test).*)",
            "destination": "/api/[...all]"
        },
        {
            "source": "/((?!api/|_vercel/|static/|favicon.ico).*)",
            "destination": "/index.html"
        }
    ]
}